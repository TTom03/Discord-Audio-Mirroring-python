# ─────────────────────────────────────────────
#  Voice Bridge – Environment Configuration
# ─────────────────────────────────────────────

# Your Discord Bot Token
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ── Source ────────────────────────────────────
SOURCE_GUILD_ID=000000000000000000
SOURCE_CHANNEL_ID=000000000000000000
SOURCE_USER_ID=000000000000000000

# ── Target 1 ─────────────────────────────────
TARGET_1_GUILD_ID=000000000000000000
TARGET_1_CHANNEL_ID=000000000000000000

# ── Target 2 ─────────────────────────────────
TARGET_2_GUILD_ID=000000000000000000
TARGET_2_CHANNEL_ID=000000000000000000

# ── Target 3 ─────────────────────────────────
TARGET_3_GUILD_ID=000000000000000000
TARGET_3_CHANNEL_ID=000000000000000000

# ── Tuning (optional, safe defaults shown) ────
# Frames to buffer before playback starts (1 frame = 20 ms).
# Lower = less latency, but more risk of stuttering on slow links.
JITTER_BUFFER_FRAMES=2

# Maximum frames kept in each target queue (~2 s worth).
# If a target falls behind, oldest frames are dropped so latency
# cannot grow unboundedly.
MAX_QUEUE_FRAMES=100
